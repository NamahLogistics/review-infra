generator client {
  provider      = "prisma-client-js"
  output        = "../../../apps/api/src/generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  stores    Store[]
}

model Store {
  storeType String @default("shopify")
  id                           String          @id @default(cuid())
  name                         String
  apiKey                       String          @unique
  createdAt                    DateTime        @default(now())
  accessToken                  String?
  plan                         String          @default("free")
  shopDomain                   String?         @unique
  userId                       String?
  connectionStatus             String          @default("draft")
  shopifyConnectedAt           DateTime?
  shopifyUninstalledAt         DateTime?
  shopifyAccessTokenExpiresAt  DateTime?
  shopifyRefreshToken          String?
  shopifyRefreshTokenExpiresAt DateTime?
  judgeMeToken                 String?
  judgeMeConnectedAt           DateTime?
  autoReviewEnabled            Boolean         @default(false)
  maxReminders                 Int             @default(2)
  sendAfterDays                Int             @default(3)
  billingEvents                BillingEvent[]
  products                     Product[]
  reviews                      Review[]
  events                       ReviewEvent[]
  nudges                       ReviewNudge[]
  orders                       ReviewOrder[]
  user                         User?           @relation(fields: [userId], references: [id])
  settings                     ReviewSettings?

  @@index([userId, createdAt])
}

model Product {
  id         String        @id @default(cuid())
  name       String
  storeId    String
  createdAt  DateTime      @default(now())
  externalId String?
  store      Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reviews    Review[]
  events     ReviewEvent[]
  nudges     ReviewNudge[]
  orders     ReviewOrder[]

  @@unique([storeId, externalId])
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  rating      Int
  text        String
  createdAt   DateTime @default(now())
  authorEmail String?
  authorName  String?
  source      String   @default("manual")
  status      String   @default("approved")
  storeId     String
  title       String?
  updatedAt   DateTime @updatedAt
  verified    Boolean  @default(false)
  ipHash      String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId, status, createdAt])
  @@index([storeId, status, createdAt])
  @@index([storeId, authorEmail, createdAt])
}

model BillingEvent {
  id        String   @id @default(cuid())
  storeId   String
  provider  String
  eventType String
  rawBody   String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
}

model ReviewNudge {
  id            String    @id @default(cuid())
  storeId       String
  productId     String
  customerName  String?
  customerEmail String
  orderRef      String?
  status        String    @default("pending")
  sentAt        DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sendAfter     DateTime?
  clickedAt     DateTime?
  lastResendAt  DateTime?
  openedAt      DateTime?
  resendCount   Int       @default(0)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status, createdAt])
  @@index([storeId, status, sendAfter])
  @@index([customerEmail, createdAt])
}

model ReviewOrder {
  id              String    @id @default(cuid())
  storeId         String
  productId       String
  externalOrderId String?
  customerName    String?
  customerEmail   String
  orderRef        String?
  nudgedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalOrderId, productId])
  @@index([storeId, createdAt])
  @@index([storeId, customerEmail, createdAt])
}

model ReviewEvent {
  id        String   @id @default(cuid())
  storeId   String
  productId String?
  reviewId  String?
  nudgeId   String?
  type      String
  payload   String
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([type, createdAt])
}

model ReviewSettings {
  id                String   @id @default(cuid())
  storeId           String   @unique
  isEnabled         Boolean  @default(true)
  nudgingLevel      String   @default("medium")
  sendDelayDays     Int      @default(3)
  followUpDelayDays Int      @default(2)
  maxReminders      Int      @default(1)
  emailSubject      String
  emailBody         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id String @id @default(cuid())
  storeId String
  customerEmail String
  customerName String?
  productId String
  createdAt DateTime @default(now())
}
